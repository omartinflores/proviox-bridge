{
  "name": "snapweb",
  "private": true,
  "version": "0.9.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:web": "cd frontend && tsc && vite build --outDir ../dist/public",
    "build:server": "esbuild backend/server.js --bundle --platform=node --format=cjs --outfile=dist/app.cjs",
    "build": "rm -rf dist && npm run build:web && npm run build:server && cp config.json dist/",
    "start": "node dist/app.cjs"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "libflacjs": "^5.4.0",
    "opus-decoder": "^0.7.11",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "standardized-audio-context": "^25.3.77"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^3.7.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.25",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^8.0.7"
  }
}
